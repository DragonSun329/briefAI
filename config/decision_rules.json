    "consumer_adoption": {
      "rising": {
        "action_type": "buy",
        "description": "Increase consumer AI exposure",
        "sector": "consumer_ai",
        "risk_level": "high",
        "reasoning": "Consumer adoption creates network effects and data moats"
      },
      "falling": {
        "action_type": "avoid",
        "description": "Avoid consumer AI without proven retention",
        "sector": "consumer_ai",
        "reasoning": "Consumer churn indicates weak product-market fit"
      }
    }
  },
  
  "sector_mappings": {
    "semiconductors": ["NVDA", "AMD", "ASML", "TSM", "AVGO", "MRVL"],
    "enterprise_software": ["CRM", "NOW", "PLTR", "SNOW", "WDAY", "DDOG"],
    "ai_applications": ["vertical SaaS", "consumer AI", "embedded AI"],
    "datacenter_infrastructure": ["VRT", "ETN", "DELL", "HPE"],
    "devtools": ["MSFT/GitHub", "NET", "MDB"]
  },
  
  "min_confidence_thresholds": {
    "buy": 0.65,
    "sell": 0.70,
    "avoid": 0.60,
    "reduce": 0.60,
    "monitor": 0.50
  }
}
