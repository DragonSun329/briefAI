  "hype_cycle": {
    "description": "Gartner-style hype cycle positioning",
    "phases": [
      {
        "id": "innovation_trigger",
        "name": "Innovation Trigger",
        "x_range": [0, 20],
        "characteristics": "Early R&D, few products, high uncertainty",
        "current_verticals": ["ai_robotics", "ai_gaming", "ai_construction"]
      },
      {
        "id": "peak_expectations",
        "name": "Peak of Inflated Expectations",
        "x_range": [20, 40],
        "characteristics": "Media hype, VC frenzy, unrealistic expectations",
        "current_verticals": ["ai_drug_discovery", "ai_education", "ai_creative", "ai_marketing"]
      },
      {
        "id": "trough_disillusionment",
        "name": "Trough of Disillusionment",
        "x_range": [40, 55],
        "characteristics": "Failures publicized, consolidation, survivors emerge",
        "current_verticals": ["ai_autonomous_vehicles", "ai_real_estate", "ai_retail"]
      },
      {
        "id": "slope_enlightenment",
        "name": "Slope of Enlightenment",
        "x_range": [55, 80],
        "characteristics": "Best practices emerge, ROI proven, enterprise adoption",
        "current_verticals": ["ai_healthcare", "ai_fintech", "ai_manufacturing", "ai_agriculture", "ai_insurance", "ai_hr", "ai_supply_chain"]
      },
      {
        "id": "plateau_productivity",
        "name": "Plateau of Productivity",
        "x_range": [80, 100],
        "characteristics": "Mainstream adoption, market leaders clear",
        "current_verticals": ["ai_trading", "ai_cybersecurity"]
      }
    ]
  },
  
  "quadrant_analysis": {
    "description": "2x2 matrix for opportunity identification",
    "axes": {
      "x": {"name": "Technical Maturity", "low": "Emerging", "high": "Mature"},
      "y": {"name": "Capital/Hype", "low": "Under-hyped", "high": "Over-hyped"}
    },
    "quadrants": [
      {
        "id": "alpha_zone",
        "name": "Alpha Zone (Hidden Gems)",
        "position": "high_tech_low_hype",
        "interpretation": "Best opportunities - proven tech, not crowded",
        "action": "Invest/Build"
      },
      {
        "id": "hot_zone",
        "name": "Hot Zone (Competitive)",
        "position": "high_tech_high_hype",
        "interpretation": "Crowded market, need differentiation",
        "action": "Differentiate or Avoid"
      },
      {
        "id": "hype_zone",
        "name": "Hype Zone (Vaporware)",
        "position": "low_tech_high_hype",
        "interpretation": "Money chasing story, high risk",
        "action": "Be Cautious"
      },
      {
        "id": "emerging_zone",
        "name": "Emerging Zone (Watch)",
        "position": "low_tech_low_hype",
        "interpretation": "Too early, monitor for breakouts",
        "action": "Research & Monitor"
      }
    ]
  },
  
  "scoring_methodology": {
    "technical_momentum_score": {
      "components": [
        {"name": "GitHub Stars Velocity", "weight": 0.15},
        {"name": "Paper Citations", "weight": 0.10},
        {"name": "Package Downloads", "weight": 0.20},
        {"name": "HuggingFace Activity", "weight": 0.15},
        {"name": "Developer Surveys", "weight": 0.10},
        {"name": "Job Postings", "weight": 0.15},
        {"name": "Patent Activity", "weight": 0.15}
      ]
    },
    "capital_confidence_score": {
      "components": [
        {"name": "Funding Volume", "weight": 0.25},
        {"name": "Funding Velocity", "weight": 0.20},
        {"name": "M&A Activity", "weight": 0.15},
        {"name": "Enterprise Contracts", "weight": 0.20},
        {"name": "VC Sentiment", "weight": 0.20}
      ]
    },
    "enterprise_adoption_score": {
      "components": [
        {"name": "Fortune 500 Usage", "weight": 0.30},
        {"name": "Enterprise Contracts", "weight": 0.25},
        {"name": "Integration Partnerships", "weight": 0.20},
        {"name": "Compliance/Security Certs", "weight": 0.25}
      ]
    }
  },
  
  "alerts": [
    {
      "id": "alpha_opportunity",
      "name": "Alpha Opportunity",
      "condition": "tech_score > 70 AND hype_score < 40",
      "description": "Undervalued opportunity with strong technical foundation"
    },
    {
      "id": "hype_warning",
      "name": "Hype Bubble Warning",
      "condition": "hype_score > 80 AND tech_score < 30",
      "description": "Dangerous hype without technical substance"
    },
    {
      "id": "breakout",
      "name": "Breakout Signal",
      "condition": "tech_score_delta > 20 in 30 days",
      "description": "Rapid technical momentum increase"
    },
    {
      "id": "maturation",
      "name": "Market Maturation",
      "condition": "moving from slope to plateau",
      "description": "Market entering mainstream phase"
    }
  ]
}
