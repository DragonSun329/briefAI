{
  "providers": [
    {
      "id": "perplexity",
      "name": "Perplexity Sonar",
      "api_url": "https://api.perplexity.ai",
      "type": "research",
      "api_key_env": "PERPLEXITY_API_KEY",
      "models": {
        "default": "sonar",
        "available": [
          "sonar",
          "sonar-pro",
          "sonar-deep-research"
        ]
      },
      "rate_limits": {
        "rpm": 20,
        "requests_per_minute": 20
      },
      "priority": 0,
      "enabled": true,
      "notes": "Search-grounded research - use sparingly ($5 budget)",
      "pricing_per_million": {
        "sonar": {
          "input": 1,
          "output": 1,
          "search_request": 5
        },
        "sonar-pro": {
          "input": 3,
          "output": 15,
          "search_request": 5
        }
      }
    },
    {
      "id": "kimi25",
      "name": "Kimi 2.5",
      "api_url": "https://api.kimi.com/coding/v1",
      "type": "primary",
      "api_key_env": "KIMI25_API_KEY",
      "api_format": "anthropic",
      "models": {
        "default": "kimi-2.5",
        "available": [
          "kimi-2.5"
        ]
      },
      "rate_limits": {
        "rpm": 30,
        "requests_per_minute": 30
      },
      "priority": 1,
      "enabled": true,
      "notes": "PRIMARY — Kimi 2.5 via Claude-compatible API. Best quality. Use for complex tasks: trend analysis, narrative generation, entity extraction, article evaluation."
    },
    {
      "id": "kimi",
      "name": "Kimi/Moonshot AI (Legacy)",
      "api_url": "https://api.moonshot.cn/v1",
      "type": "fallback",
      "api_key_env": "MOONSHOT_API_KEY",
      "models": {
        "default": "moonshot-v1-8k",
        "available": [
          "moonshot-v1-8k",
          "moonshot-v1-32k",
          "moonshot-v1-128k"
        ]
      },
      "rate_limits": {
        "rpm": 3,
        "requests_per_minute": 3
      },
      "priority": 5,
      "enabled": false,
      "notes": "DISABLED — old account suspended (no balance). Kept for reference."
    },
    {
      "id": "openrouter",
      "name": "OpenRouter",
      "api_url": "https://openrouter.ai/api/v1",
      "type": "fallback",
      "api_key_env": "OPENROUTER_API_KEY",
      "rate_limits": {
        "rpm": 200,
        "requests_per_minute": 200
      },
      "priority": 2,
      "enabled": true,
      "notes": "Fallback provider - 50+ free models available",
      "tiers": {
        "tier1_quality": {
          "description": "Best quality - reasoning models (VERIFIED WORKING)",
          "models": [
            "meta-llama/llama-3.3-70b-instruct:free",
            "nousresearch/hermes-3-llama-3.1-405b:free",
            "openai/gpt-oss-120b:free",
            "qwen/qwen3-coder:free"
          ]
        },
        "tier2_balanced": {
          "description": "Good quality and reasonable speed (VERIFIED WORKING)",
          "models": [
            "mistralai/mistral-small-3.1-24b-instruct:free",
            "google/gemma-3-27b-it:free",
            "stepfun/step-3.5-flash:free",
            "z-ai/glm-4.5-air:free"
          ]
        },
        "tier3_fast": {
          "description": "Fast response - for collection and non-critical tasks (VERIFIED WORKING)",
          "models": [
            "nvidia/nemotron-nano-9b-v2:free",
            "google/gemma-3-4b-it:free",
            "qwen/qwen3-4b:free",
            "arcee-ai/trinity-mini:free"
          ]
        }
      }
    }
  ],
  "task_model_mapping": {
    "entity_extraction": {
      "preferred_tier": "tier1_quality",
      "reason": "Requires accurate entity recognition from text"
    },
    "article_evaluation": {
      "preferred_tier": "tier1_quality",
      "reason": "Critical for ranking articles"
    },
    "article_paraphrasing": {
      "preferred_tier": "tier1_quality",
      "reason": "Highest quality summaries required"
    },
    "category_selection": {
      "preferred_tier": "tier2_balanced",
      "reason": "Simple classification task"
    },
    "general_chat": {
      "preferred_tier": "tier2_balanced",
      "reason": "Balanced approach"
    },
    "fallback_emergency": {
      "preferred_tier": "tier3_fast",
      "reason": "Last resort when all quality providers rate-limited"
    },
    "deep_research": {
      "preferred_provider": "perplexity",
      "preferred_model": "sonar",
      "reason": "Search-grounded responses with citations for company/topic research"
    },
    "company_research": {
      "preferred_provider": "perplexity",
      "preferred_model": "sonar",
      "reason": "Real-time web search for company details and news"
    }
  },
  "fallback_strategy": {
    "description": "Provider switching strategy when rate limits are hit",
    "order": [
      "openrouter.tier1_quality",
      "openrouter.tier2_balanced",
      "openrouter.tier3_fast",
      "kimi"
    ],
    "on_rate_limit": "switch_to_next_provider",
    "max_retries_per_provider": 3,
    "retry_backoff": "exponential"
  },
  "caching": {
    "cache_responses": true,
    "cache_by_content": true,
    "provider_agnostic": true,
    "description": "Cache key based on prompt content, not provider"
  }
}