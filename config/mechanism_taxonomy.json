    "pricing_cost_down": {
      "display_name": "Pricing Compression",
      "keywords": ["price cut", "cheaper", "cost reduction", "free tier", "pricing war", "discount", "commoditization", "margin compression", "race to bottom"],
      "predicted_signals": {
        "technical": {
          "description": "New efficiency techniques or distillation methods published",
          "example_sources": ["arxiv", "github", "huggingface"]
        },
        "financial": {
          "description": "Revenue guidance revisions or margin pressure in earnings",
          "example_sources": ["sec", "earnings_call", "analyst_report"]
        },
        "social": {
          "description": "Developer discourse on cost optimization strategies",
          "example_sources": ["twitter", "reddit", "hackernews"]
        },
        "media": {
          "description": "Coverage of pricing changes or competitive responses",
          "example_sources": ["techmeme", "techcrunch", "theinformation"]
        }
      },
      "falsifiers": [
        "Prices stabilize or increase across providers",
        "Demand exceeds supply causing price floors",
        "Quality differentiation justifies premium pricing"
      ]
    },
    
